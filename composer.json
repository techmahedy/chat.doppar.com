{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "doppar/doppar",
    "type": "project",
    "description": "The skeleton application for the Doppar framework",
    "license": "MIT",
    "keywords": [
        "framework",
        "Doppar"
    ],
    "require": {
        "php": "^8.3",
        "doppar/ai": "^1.4",
        "doppar/framework": "3.*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.x-dev"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php pool key:generate",
            "@php pool migrate"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout"
        ],
        "test": [
            "@php pool config:clear --ansi"
        ],
        "post-create-project-cmd": [
            "Phaseolies\\Installer::preInstall",
            "Phaseolies\\Installer::postCreateProject",
            "@php pool key:generate --ansi",
            "@php pool package:install --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php pool boost --ansi",
            "@php pool migrate --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "codewithkyrian/platform-package-installer": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
